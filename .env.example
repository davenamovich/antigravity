# =============================================================
# ANTIGRAVITY — MASTER ENV VARS
# Copy to .env and fill in values. Never commit .env
# =============================================================

# ── LLM: Chutes.ai ──────────────────────────────────────────
CHUTES_API_KEY=
CHUTES_BASE_URL=https://llm.chutes.ai/v1
# Model to use for slide copy generation (open-source, fast)
CHUTES_MODEL=deepseek-ai/DeepSeek-V3-0324

# ── Fallback LLM ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database (Railway injects these automatically) ───────────
DATABASE_URL=postgresql://user:pass@host:5432/vessel
PAPERCLIP_DATABASE_URL=postgresql://user:pass@host:5432/paperclip

# ── Redis (Railway injects automatically) ────────────────────
REDIS_URL=redis://default:pass@host:6379

# ── Postiz ───────────────────────────────────────────────────
POSTIZ_MAIN_APP_URL=https://postiz.yourdomain.railway.app
POSTIZ_FRONTEND_URL=https://postiz.yourdomain.railway.app
POSTIZ_JWT_SECRET=                    # openssl rand -base64 32
POSTIZ_API_KEY=                       # from Postiz Settings → API Keys
POSTIZ_API_URL=https://postiz.yourdomain.railway.app/public/v1
DISABLE_REGISTRATION=true             # set true AFTER first account

# ── Moltis ───────────────────────────────────────────────────
MOLTIS_PORT=13131

# ── Paperclip ────────────────────────────────────────────────
PAPERCLIP_JWT_SECRET=                 # openssl rand -base64 32
PAPERCLIP_PORT=3100

# ── Vessel API ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://vessel.yourdomain.railway.app
PRIVY_APP_ID=
PRIVY_APP_SECRET=
BASE_RPC_URL=https://mainnet.base.org
VESSEL_FEE_ROUTER_ADDRESS=

# ── Slideshow Service ────────────────────────────────────────
SLIDESHOW_PORT=3500
SLIDESHOW_SERVICE_URL=http://slideshow:3500

# ── Ralph Loop ───────────────────────────────────────────────
RALPH_LOOP_PORT=3600
COMPOSIO_API_KEY=

# ── Social Platform OAuth (for Postiz providers) ─────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
